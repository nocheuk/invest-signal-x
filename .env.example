VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-only. Never expose this in the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CRON_SECRET=your-random-cron-secret
APP_BASE_URL=https://your-production-app.example.com

# Optional server-only email provider for Saved Alerts V1.
# If omitted, alert matches are recorded but emails are marked provider_not_configured.
RESEND_API_KEY=your-resend-api-key
ALERT_EMAIL_FROM=DealSignal <alerts@example.com>

# Server-only Apify import settings. Never expose APIFY_TOKEN to Vite/frontend code.
APIFY_TOKEN=your-apify-token
RIGHTMOVE_COMMERCIAL_ACTOR_ID=dhrumil/rightmove-commercial-scraper
